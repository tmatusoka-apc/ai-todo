{
  "name": "ai-todo-cdk",
  "version": "0.1.0",
  "bin": {
    "cdk": "bin/app.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "cdk": "cdk",
    "deploy:all": "cdk deploy --all --require-approval never",
    "deploy:security": "cdk deploy AiTodoSecurityStack",
    "deploy:infra": "cdk deploy AiTodoInfraStack",
    "deploy:app": "cdk deploy AiTodoAppStack",
    "destroy": "cdk destroy --all",
    "diff": "cdk diff --all",
    "synth": "cdk synth"
  },
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/client-secrets-manager": "^3.0.0",
    "@aws-sdk/lib-dynamodb": "^3.0.0",
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^20.0.0",
    "aws-cdk": "^2.170.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.170.0",
    "constructs": "^10.0.0"
  }
}
